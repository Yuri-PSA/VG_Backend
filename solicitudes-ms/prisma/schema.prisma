generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas = ["core"]
}


// DATABASE MODELS
model Solicitud {
  solicitud_id          Int                 @id @default(autoincrement())
  usuario_id            Int
  folio_solicitud       String              @unique
  fecha_recepcion       DateTime            @default(now())
  inicio_viaje          DateTime
  fin_viaje             DateTime
  destino               String
  motivo                String
  monto_solicitado      Decimal             @db.Decimal(10, 2)
  monto_moneda          String
  forma_pago            FormaPago
  estado                EstadoSol           @default(Pendiente)
  estado_financiero     EstadoFinanciero?
  fecha_entrega         DateTime?
  fecha_confirmacion    DateTime?
  ruta_comprobante      String?
  fecha_actualizacion   DateTime            @default(now()) @updatedAt
 
  comprobacion          Comprobacion?
  liquidacion           Liquidacion?
  aprobaciones          Aprobacion[] @relation("AprobacionSolicitud")

  @@schema("core")
  @@map("solicitud")
}

model Comprobacion {
  comprobacion_id       Int                 @id @default(autoincrement())
  solicitud_id          Int                 @unique
  folio_comprobacion    String              @unique
  fecha_comprobacion    DateTime            @default(now())
  total_importe         Decimal             @db.Decimal(10, 2)
  total_iva             Decimal             @db.Decimal(10, 2)
  total                 Decimal             @db.Decimal(10, 2)
  total_moneda          String
  saldo                 Decimal             @db.Decimal(10, 2)
  saldo_moneda          String
  estado                EstadoCmp           @default(Pendiente)
  fecha_actualizacion   DateTime            @default(now()) @updatedAt

  solicitud             Solicitud @relation(fields: [solicitud_id], references: [solicitud_id])
 
  facturas              Factura[]
  aprobaciones          Aprobacion[] @relation("AprobacionComprobacion")

  @@schema("core")
  @@map("comprobacion")
}

model Factura {
  factura_id            Int                 @id @default(autoincrement())
  comprobacion_id       Int
  folio_factura         String              @unique
  fecha_factura         DateTime
  proveedor             String
  concepto              String
  descripcion           String
  importe               Decimal             @db.Decimal(10, 2)
  iva                   Decimal             @db.Decimal(10, 2)
  otros_montos          Decimal             @default(0) @db.Decimal(10, 2)
  total                 Decimal             @db.Decimal(10, 2)
  total_moneda          Decimal             @db.Decimal(10, 2)
  tipo_moneda           String
  ruta_xml              String?
  ruta_pdf              String?
  ruta_jpg              String?

  comprobacion          Comprobacion @relation(fields: [comprobacion_id], references: [comprobacion_id])

  tipos_cambio           TiposCambio?

  @@schema("core")
  @@map("factura")
}

model TiposCambio {
  tipos_cambio_id       Int                 @id @default(autoincrement())
  factura_id            Int                 @unique
  fecha_tipo_cambio     DateTime
  moneda                String
  tipo_cambio           Decimal             @db.Decimal(10, 2)

  factura               Factura @relation(fields: [factura_id], references: [factura_id])

  @@schema("core")
  @@map("tipos_cambio")
}

model Aprobacion {
  aprobacion_id         Int                 @id @default(autoincrement())
  usuario_id            Int
  solicitud_id          Int?
  comprobacion_id       Int?
  fecha_hora            DateTime            @default(now())
  accion                Acciones
  motivo_rechazo        String?

  solicitud             Solicitud? @relation("AprobacionSolicitud", fields: [solicitud_id], references: [solicitud_id])
  comprobacion          Comprobacion? @relation("AprobacionComprobacion", fields: [comprobacion_id], references: [comprobacion_id])

  @@schema("core")
  @@map("aprobacion")
}

model Notificacion {
  notificacion_id       Int                 @id @default(autoincrement())
  tipo                  TipoNotificacion
  evento                EventoNotificacion
  asunto                String
  cuerpo                String

  usuarios              NotificacionUsuario[]

  @@schema("core")
  @@map("notificacion")
}

model NotificacionUsuario {
  notificacion_usuario_id   Int             @id @default(autoincrement())
  usuario_id            Int
  notificacion_id       Int
  fecha_envio           DateTime            @default(now())

  notificacion          Notificacion @relation(fields: [notificacion_id], references: [notificacion_id])

  @@schema("core")
  @@map("notificacion_usuario")
}

model Liquidacion {
  liquidacion_id        Int                 @id @default(autoincrement())
  solicitud_id          Int                 @unique
  total_autorizado      Decimal             @db.Decimal(10, 2)
  total_comprobado      Decimal             @db.Decimal(10, 2)
  diferencia            Decimal             @db.Decimal(10, 2)
  tipo_ajuste           TipoAjuste
  estado                EstadoLiquidacion
  fecha_calculo         DateTime
  fecha_pago            DateTime?
  fecha_recibido        DateTime?
  ruta_comprobacion     String?

  solicitud             Solicitud @relation(fields: [solicitud_id], references: [solicitud_id])

  @@schema("core")
  @@map("liquidacion")
}


// ENUMS
enum FormaPago {
  Transferencia
  Efectivo

  @@schema("core")
}

enum EstadoSol {
  Pendiente
  Aprobada
  Rechazada
  Cancelada

  @@schema("core")
}

enum EstadoFinanciero {
  Pendiente
  Liquidada

  @@schema("core")
}

enum EstadoCmp {
  Pendiente
  Aprobada
  Rechazada

  @@schema("core")
}

enum Acciones {
  Aprobar
  Rechazar

  @@schema("core")
}

enum TipoNotificacion {
  Solicitud
  Comprobación
  Anticipo

  @@schema("core")
}

enum EventoNotificacion {
  Aprobada
  Rechazada
  Enviada
  Cancelada
  Modificada
  Vencida
  Recordatorio
  Liquidada

  @@schema("core")
}

enum TipoAjuste {
  Devolución
  Reembolso
  Sin_diferencia

  @@schema("core")
}

enum EstadoLiquidacion {
  Pendiente
  Pagado
  Devuelto
  Saldado

  @@schema("core")
}